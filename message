<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>eerrgin.github.io</title>
    <style>
        /* Genel Sayfa Tasarımı */
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            text-align: center;
            padding-top: 50px;
        }

        /* Ana Konteyner ve Gizli Nokta */
        .message-container {
            display: inline-flex;
            align-items: flex-end;
            margin-top: 20px;
        }

        #open-msg-btn {
            padding: 10px 20px;
            background-color: #333;
            color: #fff;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
        }

        #open-msg-btn:hover {
            background-color: #555;
        }

        #secret-login-dot {
            cursor: pointer;
            color: #ccc;
            font-size: 10px;
            margin-left: 3px;
            opacity: 0.2; /* Neredeyse görünmez */
            user-select: none;
        }

        /* Açılır Pencere (Modal) Tasarımı */
        .custom-modal {
            display: none; 
            position: fixed; 
            z-index: 1000; 
            left: 0;
            top: 0;
            width: 100%; 
            height: 100%; 
            background-color: rgba(0,0,0,0.6); 
        }

        .modal-content {
            background-color: #fefefe;
            margin: 10% auto; 
            padding: 20px;
            border-radius: 8px;
            width: 90%;
            max-width: 400px;
            text-align: left;
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        }

        .modal-content input, .modal-content textarea {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
            border: 1px solid #ccc;
            border-radius: 4px;
            box-sizing: border-box;
        }

        #send-btn {
            width: 100%;
            padding: 10px;
            background-color: #28a745;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
        }

        #send-btn:hover {
            background-color: #218838;
        }

        .close-btn {
            color: #aaa;
            float: right;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
        }

        .close-btn:hover {
            color: black;
        }
    </style>
</head>
<body>

    <h1>Welcome to eerrgin</h1>
    <p>This is a personal webpage.</p>
    
    <div class="message-container">
        <button id="open-msg-btn">Send a Message</button>
        <span id="secret-login-dot">.</span>
    </div>

    <div id="msg-modal" class="custom-modal">
        <div class="modal-content">
            <span class="close-btn" id="close-msg">&times;</span>
            <h2>Leave a Message</h2>
            <input type="text" id="sender-name" placeholder="Your Name" required>
            <textarea id="sender-msg" rows="5" placeholder="Write your message here..." required></textarea>
            <button id="send-btn">Send</button>
        </div>
    </div>

    <div id="admin-modal" class="custom-modal">
        <div class="modal-content">
            <span class="close-btn" id="close-admin">&times;</span>
            <h2>Inbox (Admin)</h2>
            <div id="message-list">
                <p style="color: #666; font-size: 14px;">Messages will appear here after backend integration.</p>
            </div>
        </div>
    </div>

    <script>
        // Elementleri Yakalama
        const msgModal = document.getElementById("msg-modal");
        const adminModal = document.getElementById("admin-modal");
        const openMsgBtn = document.getElementById("open-msg-btn");
        const secretDot = document.getElementById("secret-login-dot");
        const closeMsg = document.getElementById("close-msg");
        const closeAdmin = document.getElementById("close-admin");
        const sendBtn = document.getElementById("send-btn");

        // Ziyaretçi Ekranını Aç
        openMsgBtn.onclick = function() {
            msgModal.style.display = "block";
        }

        // Gizli Noktaya Tıklama ve Şifre (1845)
        secretDot.onclick = function() {
            let pass = prompt("Access Code:");
            if (pass === "1845") {
                adminModal.style.display = "block";
            } else if (pass !== null) {
                alert("Access Denied.");
            }
        }

        // Kapatma Tuşları (X)
        closeMsg.onclick = function() { msgModal.style.display = "none"; }
        closeAdmin.onclick = function() { adminModal.style.display = "none"; }

        // Boşluğa Tıklayınca Kapat
        window.onclick = function(event) {
            if (event.target == msgModal) msgModal.style.display = "none";
            if (event.target == adminModal) adminModal.style.display = "none";
        }

        // Gönder Butonu İşlevi
        sendBtn.onclick = function() {
            let name = document.getElementById("sender-name").value;
            let msg = document.getElementById("sender-msg").value;
            
            if(name === "" || msg === "") {
                alert("Please fill all fields.");
                return;
            }
            
            sendBtn.innerText = "Sent!";
            sendBtn.style.backgroundColor = "#17a2b8";
            
            setTimeout(() => {
                msgModal.style.display = "none";
                sendBtn.innerText = "Send";
                sendBtn.style.backgroundColor = "#28a745";
                document.getElementById("sender-name").value = "";
                document.getElementById("sender-msg").value = "";
            }, 1500);
        }
    </script>
</body>
</html>
